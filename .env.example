# PIN untuk login dashboard (default: 929283)
FINANCE_PIN=929283

# Secret untuk cookie session — minimal 32 karakter
SESSION_SECRET=ganti-secret-panjang-min-32-char-disini-please

# Secret yang dipake Semar di header x-minion-secret untuk POST ke /api/entry
MINION_SECRET=semar-finance-2026-secret-change-me

# Path database SQLite (default: ./data/finance.db)
# Di production Coolify, mount ke volume biar persistent
# FINANCE_DB_PATH=/data/finance.db
